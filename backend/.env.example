PORT=4000

# Local MySQL (phpMyAdmin / XAMPP / MAMP) — default port 3306
DATABASE_URL=mysql://root@127.0.0.1:3306/cms_tagrobotech

# Docker MySQL (only if using docker compose) — port 3307
# DATABASE_URL=mysql://cms:cms_password@127.0.0.1:3307/cms_tagrobotech

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Resend — lead notification emails
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Tag RoBo Tech <onboarding@resend.dev>
LEADS_NOTIFY_EMAIL=you@example.com
