{
  "name": "cms-tagrobotech",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n backend,admin,frontend -c blue,magenta,green \"npm run dev --prefix backend\" \"npm run dev --prefix admin-panel\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:admin": "npm run dev --prefix admin-panel",
    "dev:frontend": "npm run dev --prefix frontend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:seed": "npm run db:seed --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
